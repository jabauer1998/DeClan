SYMBOL SECTION
 ENTRY a INTERNAL PARAM c WriteChar 0 <CHAR>
DATA SECTION
PROC SECTION
 PROC LABEL WriteLn
  DEF b := \ <CHAR>
  CALL WriteChar([b -> a]<CHAR>)
 RETURN FROM WriteLn
 PROC LABEL WriteChar
  IPARAM (PARAM a) <CHAR> %ua
  IASM "LDRB R0, %ua"
  IASM "SWI WriteChar"
 RETURN FROM WriteChar
