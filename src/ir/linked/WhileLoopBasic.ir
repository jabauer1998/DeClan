SYMBOL SECTION
 ENTRY f24 INTERNAL GLOBAL x  <INT>
 ENTRY f26 CONST INTERNAL GLOBAL max  <INT>
BSS SECTION
 DEF GLOBAL f24 := 0 <INT>
DATA SECTION
