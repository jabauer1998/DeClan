 DEF GLOBAL f26 := f25 <INT>
CODE SECTION
 DEF f27 := 0 <INT>
 GLOBAL f24 := f27 <INT>
 DEF f28 := (GLOBAL f24) LT (GLOBAL f26) <BOOL>
 DEF f29 := TRUE <BOOL>
 IF f28 BEQ f29
 THEN WHILESTAT_0_SEQ_0_LEVEL_0_0
 ELSE WHILENEXT_0_SEQ_0_LEVEL_0_0
 LABEL WHILECOND_0_SEQ_0_LEVEL_0_0
 IF f28 BEQ f29
