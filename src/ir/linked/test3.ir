  GOTO IFEND_0_LEVEL_0
  LABEL IFNEXT_0_SEQ_0_LEVEL_0
  DEF n63 := 0 <INT>
  DEF n64 := (PARAM n52) GT n63 <BOOL>
  DEF n65 := TRUE <BOOL>
  IF n64 BEQ n65
  THEN IFSTAT_0_SEQ_1_LEVEL_0
  ELSE IFNEXT_0_SEQ_1_LEVEL_0_4
  LABEL IFSTAT_0_SEQ_1_LEVEL_0
  DEF n66 := 0 <INT>
  DEF n67 := 1 <INT>
  DEF n68 := (PARAM n52) ISUB n67 <INT>
  CALL WriteFractionDigit([n66 -> n50]<INT>, [n68 -> n52]<INT>)
  DEF n69 := '0' <CHAR>
  CALL WriteChar([n69 -> k30]<CHAR>)
  GOTO IFEND_0_LEVEL_0
  LABEL IFNEXT_0_SEQ_1_LEVEL_0_4
  DEF n70 := '0' <CHAR>
  CALL WriteChar([n70 -> k30]<CHAR>)
  GOTO IFEND_0_LEVEL_0
  LABEL IFNEXT_0_SEQ_2_LEVEL_0
  LABEL IFEND_0_LEVEL_0
 RETURN FROM WriteFractionDigit
