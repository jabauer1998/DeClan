SYMBOL SECTION
 ENTRY f24 INTERNAL GLOBAL n  <INT>
 ENTRY f25 INTERNAL GLOBAL i  <INT>
 ENTRY f26 INTERNAL GLOBAL result  <INT>
 ENTRY f30 INTERNAL temp F <INT>
 ENTRY f31 INTERNAL result F <INT>
 ENTRY f34 INTERNAL PARAM n F 0 <INT>
 ENTRY f40 INTERNAL RETURN F <INT>
 ENTRY f41 INTERNAL temp M <INT>
 ENTRY f42 INTERNAL result M <INT>
 ENTRY f45 INTERNAL PARAM n M 0 <INT>
 ENTRY f51 INTERNAL RETURN M <INT>
 ENTRY f58 INTERNAL temp Fact <INT>
 ENTRY f59 INTERNAL result Fact <INT>
 ENTRY f62 INTERNAL PARAM n Fact 0 <INT>
 ENTRY f68 INTERNAL RETURN Fact <INT>
 ENTRY f69 INTERNAL low Multiply <INT>
 ENTRY f70 INTERNAL PARAM a Multiply 0 <INT>
 ENTRY f71 INTERNAL PARAM b Multiply 1 <INT>
 ENTRY f72 INTERNAL RETURN Multiply <INT>
BSS SECTION
 DEF GLOBAL f24 := 0 <INT>
 DEF GLOBAL f25 := 0 <INT>
 DEF GLOBAL f26 := 0 <INT>
DATA SECTION
CODE SECTION
 CALL ReadInt()
 DEF f27 := (RETURN f28) <INT>
 GLOBAL f24 := f27 <INT>
 DEF f29 := 0 <INT>
 GLOBAL f25 := f29 <INT>
 LABEL FORBEG_0_LEVEL_0
 IF (GLOBAL f25) LT (GLOBAL f24)
 THEN FORLOOP_0_LEVEL_0
 ELSE FOREND_0_LEVEL_0
 LABEL FORLOOP_0_LEVEL_0
 CALL F([(GLOBAL f25) -> f34]<INT>)
 DEF f56 := (RETURN f40) <INT>
 GLOBAL f26 := f56 <INT>
 CALL WriteInt([(GLOBAL f26) -> f75]<INT>)
 CALL Fact([(GLOBAL f25) -> f62]<INT>)
 DEF f74 := (RETURN f68) <INT>
 GLOBAL f26 := f74 <INT>
 CALL WriteInt([(GLOBAL f26) -> f75]<INT>)
 CALL WriteLn()
 DEF f78 := 1 <INT>
 GLOBAL f25 := (GLOBAL f25) IADD f78 <INT>
 GOTO FORBEG_0_LEVEL_0
 LABEL FOREND_0_LEVEL_0
END
PROC SECTION
 PROC LABEL F
  DEF f30 := 0 <INT>
  DEF f31 := 0 <INT>
  DEF f32 := 0 <INT>
  DEF f33 := (PARAM f34) IEQ f32 <BOOL>
  DEF f35 := TRUE <BOOL>
  IF f33 BEQ f35
  THEN IFSTAT_1_SEQ_0_LEVEL_0_0
  ELSE IFNEXT_1_SEQ_0_LEVEL_0_0
  LABEL IFSTAT_1_SEQ_0_LEVEL_0_0
  DEF f36 := 1 <INT>
  f31 := f36 <INT>
  GOTO IFEND_1_LEVEL_0_0
  LABEL IFNEXT_1_SEQ_0_LEVEL_0_0
  DEF f37 := 1 <INT>
  DEF f38 := (PARAM f34) ISUB f37 <INT>
  CALL F([f38 -> f34]<INT>)
  DEF f39 := (RETURN f40) <INT>
  f30 := f39 <INT>
  CALL M([f30 -> f45]<INT>)
  DEF f54 := (RETURN f51) <INT>
  f31 := f54 <INT>
  DEF f55 := (PARAM f34) ISUB f31 <INT>
  f31 := f55 <INT>
  GOTO IFEND_1_LEVEL_0_0
  LABEL IFNEXT_1_SEQ_1_LEVEL_0_0
  LABEL IFEND_1_LEVEL_0_0
  DEF RETURN f40 := f31 <INT>
 RETURN FROM F
 PROC LABEL M
  DEF f41 := 0 <INT>
  DEF f42 := 0 <INT>
  DEF f43 := 0 <INT>
  DEF f44 := (PARAM f45) IEQ f43 <BOOL>
  DEF f46 := TRUE <BOOL>
  IF f44 BEQ f46
  THEN IFSTAT_0_SEQ_0_LEVEL_0_0
  ELSE IFNEXT_0_SEQ_0_LEVEL_0_0
  LABEL IFSTAT_0_SEQ_0_LEVEL_0_0
  DEF f47 := 0 <INT>
  f42 := f47 <INT>
  GOTO IFEND_0_LEVEL_0_0
  LABEL IFNEXT_0_SEQ_0_LEVEL_0_0
  DEF f48 := 1 <INT>
  DEF f49 := (PARAM f45) ISUB f48 <INT>
  CALL M([f49 -> f45]<INT>)
  DEF f50 := (RETURN f51) <INT>
  f41 := f50 <INT>
  CALL F([f41 -> f34]<INT>)
  DEF f52 := (RETURN f40) <INT>
  f42 := f52 <INT>
  DEF f53 := (PARAM f45) ISUB f42 <INT>
  f42 := f53 <INT>
  GOTO IFEND_0_LEVEL_0_0
  LABEL IFNEXT_0_SEQ_1_LEVEL_0_0
  LABEL IFEND_0_LEVEL_0_0
  DEF RETURN f51 := f42 <INT>
 RETURN FROM M
 PROC LABEL Fact
  DEF f58 := 0 <INT>
  DEF f59 := 0 <INT>
  DEF f60 := 0 <INT>
  DEF f61 := (PARAM f62) IEQ f60 <BOOL>
  DEF f63 := TRUE <BOOL>
  IF f61 BEQ f63
  THEN IFSTAT_2_SEQ_0_LEVEL_0_0
  ELSE IFNEXT_2_SEQ_0_LEVEL_0_0
  LABEL IFSTAT_2_SEQ_0_LEVEL_0_0
  DEF f64 := 1 <INT>
  f59 := f64 <INT>
  GOTO IFEND_2_LEVEL_0_0
  LABEL IFNEXT_2_SEQ_0_LEVEL_0_0
  DEF f65 := 1 <INT>
  DEF f66 := (PARAM f62) ISUB f65 <INT>
  CALL Fact([f66 -> f62]<INT>)
  DEF f67 := (RETURN f68) <INT>
  f58 := f67 <INT>
  CALL Multiply([(PARAM f62) -> f70]<INT>, [f58 -> f71]<INT>)
  DEF f73 := (RETURN f72) <INT>
  f59 := f73 <INT>
  GOTO IFEND_2_LEVEL_0_0
  LABEL IFNEXT_2_SEQ_1_LEVEL_0_0
  LABEL IFEND_2_LEVEL_0_0
  DEF RETURN f68 := f59 <INT>
 RETURN FROM Fact
 PROC LABEL Multiply
  DEF f69 := 0 <INT>
  IPARAM f69 <INT> %dr
  IPARAM (PARAM f70) <INT> %ur
  IPARAM (PARAM f71) <INT> %ur
  IASM "MUL %dr, %ur, %ur"
  DEF RETURN f72 := f69 <INT>
 RETURN FROM Multiply
 PROC LABEL WriteLn
  DEF f76 := \ <CHAR>
  CALL WriteChar([f76 -> f77]<CHAR>)
 RETURN FROM WriteLn
 PROC LABEL WriteChar
  IPARAM (PARAM f77) <CHAR> %ua
  IASM "LDRB R0, %ua"
  IASM "SWI WriteChar"
 RETURN FROM WriteChar
